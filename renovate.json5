{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  reviewers: [
    'Soli0222',
  ],
  timezone: 'Asia/Tokyo',
  prConcurrentLimit: 15,
  prHourlyLimit: 8,
  labels: [
    'dependencies',
  ],
  enabledManagers: [
    'ansible',
    'ansible-galaxy',
    'flux',
    'github-actions',
    'helmfile',
    'helm-requirements',
    'helm-values',
    'kubernetes',
    'custom.regex',
    'terraform',
  ],
  flux: {
    managerFilePatterns: [
      '/(^|/)flux/.+\\.ya?ml$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/(^|/)flux/.+/cronjob-.+\\.ya?ml$/',
    ],
  },
  packageRules: [
    {
      matchManagers: [
        'terraform',
      ],
      commitMessageTopic: 'Terraform {{depName}}',
      addLabels: [
        'manager:terraform',
      ],
    },
    {
      matchManagers: [
        'helmfile',
        'helm-requirements',
        'helm-values',
      ],
      commitMessageTopic: 'Helm chart {{depName}}',
      addLabels: [
        'manager:helm',
      ],
    },
    {
      matchManagers: [
        'flux',
      ],
      commitMessageTopic: 'Flux {{depName}}',
      addLabels: [
        'manager:flux',
      ],
    },
    {
      matchManagers: [
        'ansible',
        'ansible-galaxy',
      ],
      commitMessageTopic: 'Ansible {{depName}}',
      addLabels: [
        'manager:ansible',
      ],
    },
    {
      matchManagers: [
        'kubernetes',
      ],
      commitMessageTopic: 'Kubernetes image {{depName}}',
      addLabels: [
        'manager:kubernetes',
      ],
    },
    {
      matchManagers: [
        'github-actions',
      ],
      commitMessageTopic: 'GitHub Action {{depName}}',
      addLabels: [
        'manager:github-actions',
      ],
      separateMinorPatch: true,
      automerge: true,
      automergeType: 'pr',
      platformAutomerge: false,
    },
    {
      matchManagers: [
        'custom.regex',
      ],
      matchDepNames: [
        'etcd-io/etcd',
        'k3s-io/k3s',
      ],
      commitMessageTopic: 'Ansible {{depName}}',
      addLabels: [
        'manager:ansible-vars',
      ],
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/ansible/(?:inventories/group_vars|roles/.+/defaults)/.*\\.ya?ml$/',
      ],
      matchStrings: [
        'etcd_version:\\s*"(?<currentValue>[^"]+)"',
      ],
      depNameTemplate: 'etcd-io/etcd',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '/ansible/(?:inventories/group_vars|roles/.+/defaults)/.*\\.ya?ml$/',
      ],
      matchStrings: [
        'k3s_version:\\s*"(?<currentValue>[^"]+)"',
      ],
      depNameTemplate: 'k3s-io/k3s',
      datasourceTemplate: 'github-releases',
      versioningTemplate: 'semver',
    },
  ],
}
